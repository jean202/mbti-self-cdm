{
  "name": "mbti-self-cdm-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "bootstrap:local": "bash scripts/bootstrap-local.sh",
    "bootstrap:local:clean": "bash scripts/bootstrap-local.sh --clean",
    "build": "tsc -p tsconfig.build.json",
    "db:seed": "tsx prisma/seed.ts",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f postgres redis",
    "infra:up": "docker compose up -d --wait postgres redis",
    "prisma:format": "prisma format --schema prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma",
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "test:provider-verifier": "npm run build && node scripts/test-provider-verification.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "export:openapi": "npm run build && node scripts/export-openapi.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "verify:auth-flow": "npm run build && node scripts/verify-auth-flow.js",
    "verify:calendar-flow": "npm run build && node scripts/verify-calendar-flow.js",
    "verify:calendar-oauth-callback": "npm run build && node scripts/verify-calendar-oauth-callback.js",
    "verify:calendar-oauth-start": "npm run build && node scripts/verify-calendar-oauth-start.js",
    "verify:mbti-onboarding": "npm run build && node scripts/verify-mbti-onboarding.js",
    "verify:local": "bash scripts/verify-local.sh",
    "verify:local:clean": "bash scripts/verify-local.sh --clean",
    "verify:vertical-slice": "npm run build && node scripts/verify-vertical-slice.js"
  },
  "dependencies": {
    "@fastify/static": "^9.1.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-fastify": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/client": "^6.19.2",
    "bullmq": "^5.71.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "fastify": "^5.8.4",
    "ioredis": "^5.10.1",
    "prisma": "^6.19.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
