    },
    {
      "key": "passive_voice_prompts",
      "rule": "지나치게 우회적이고 힘 빠지는 문구를 기본값으로 쓰지 않는다"
    },
    {
      "key": "endless_reflection",
      "rule": "회고를 너무 길고 느슨하게 만들지 않는다"
    }
