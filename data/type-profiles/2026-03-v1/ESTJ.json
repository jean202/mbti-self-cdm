        "order": 2,
        "action_key": "cut_to_top_priority",
        "duration_minutes": 3
      },
      {
        "order": 3,
        "action_key": "rebuild_realistic_order",
        "duration_minutes": 4
      }
    ],
    "recommended_prompt_keys": [
      "priority_cut_reset",
      "realistic_reorder_note",
      "brief_pause_breath"
    ]
  },
