    "backlog_strategy": "sort_by_obligation_and_due_date",
    "default_sort": [
      "due_soon",
      "today_focus_linked",
      "oldest_open"
    ]
  },
  "reminder_tone": {
    "tone_key": "clear_brief",
    "intensity_floor": "medium",
    "intensity_ceiling": "high",
    "cadence_bias": "steady"
  },
  "review_prompts": [
    {
      "key": "completion_check",
      "surface": "reflect",
      "intent": "오늘 마무리된 일과 남은 일을 분명히 확인"
    },
    {
      "key": "deviation_point",
      "surface": "reflect",
      "intent": "계획에서 벗어난 지점이 어디였는지 파악"
    },
    {
      "key": "tomorrow_order",
      "surface": "reflect",
      "intent": "내일의 순서를 미리 정해 불확실성을 줄이기"
    }
  ],
  "stress_signals": [
    {
      "key": "unclosed_loops",
      "trigger_hint": "열어둔 일은 많은데 끝난 일이 거의 없음",
      "ui_escalation": "show_recovery_card"
    },
    {
      "key": "unexpected_change_stack",
      "trigger_hint": "계획 밖 변경이 한꺼번에 겹침",
      "ui_escalation": "raise_reflection_prompt"
    },
    {
      "key": "silent_overwork",
      "trigger_hint": "쉬지 않고 버티지만 피로 신호를 무시함",
      "ui_escalation": "suppress_extra_prompts"
    }
  ],
  "recovery_protocol": {
    "protocol_key": "stabilize_and_reset_sequence",
    "default_duration_minutes": 10,
    "steps": [
      {
        "order": 1,
        "action_key": "review_open_loops",
        "duration_minutes": 3
      },
      {
        "order": 2,
        "action_key": "pick_next_clear_step",
        "duration_minutes": 3
      },
      {
        "order": 3,
        "action_key": "make_small_reset",
        "duration_minutes": 4
      }
    ],
    "recommended_prompt_keys": [
      "sequence_reset_3m",
      "close_one_loop",
      "desk_reset_short"
    ]
  },
  "forbidden_patterns": [
    {
      "key": "ambiguous_prompting",
      "rule": "해야 할 행동이 모호한 프롬프트를 첫 화면 핵심 위치에 두지 않는다"
    },
    {
      "key": "last_minute_flood",
      "rule": "마감 직전에 reminder를 과도하게 몰아 보내지 않는다"
    },
    {
      "key": "emotional_guilt_language",
      "rule": "감정 압박 위주의 reminder 문구를 사용하지 않는다"
    }
  ],
  "micro_adjustment_bounds": {
