      {
        "type_code": "INTJ",
        "difference_summary": "장기 전략을 넓게 그리기보다 당장 신뢰할 수 있는 기준과 누락 없는 실행 안정성에 더 빨리 반응한다"
      }
    ]
  },
  "home_mode": {
    "mode_key": "steady_checklist",
    "default_interaction": "structured",
    "card_priority": [
      "today_focus",
      "priority_tasks",
      "calendar_summary",
      "personalized_prompt",
      "recovery_card"
    ],
    "empty_state_route": "task_list_first",
    "overload_card_priority": "raise_recovery_card"
  },
  "task_capture_style": {
    "style_key": "checklist_first",
    "default_target_bias": "TASK",
